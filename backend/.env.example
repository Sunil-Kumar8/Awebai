# Port for the Express server to run on
PORT=5000

# MongoDB Atlas Connection URI
# Replace with your actual Atlas connection string: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://awebai:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/Awebai?retryWrites=true&w=majority

# Frontend Origin for CORS configuration
# Allowed origins (use comma-separated values for multiple origins)
FRONTEND_URL=http://localhost:8080,http://127.0.0.1:8080
